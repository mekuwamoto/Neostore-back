{
  "Database": {
    "Server": "localhost",
    "Port": 3306,
    "Database": "neostore",
    "User": "root",
    "Password": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/neostore-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName"]
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "S3": {
    "ServiceUrl": "",
    "AccessKey": "",
    "SecretKey": "",
    "Region": "us-east-1",
    "BucketImagens": "neostore-imagens"
  },
  "AllowedHosts": "*"
}
