{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet build src/Neostore.slnx",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test",
            "command": "dotnet test src/Neostore.slnx",
            "type": "shell",
            "group": "test",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run",
            "command": "dotnet run --project src/Neostore.Api",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": "$msCompile"
        }
    ]
}